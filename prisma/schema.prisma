generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoDenuncia {
  SOM_ALTO
  DROGAS
  ANIMAIS
  LIXO
  AMBULANTE_IRREGULAR
  CRIANCA_PERDIDA
  OUTROS
}

model Denuncia {
  id            String         @id @default(uuid())
  tipo          TipoDenuncia
  descricao     String?
  latitude      Float
  longitude     Float
  sessionId     String
  ativa         Boolean        @default(true)
  fotoBase64    String?        @db.Text
  confirmacoes  Int            @default(0)
  criadoEm      DateTime       @default(now())
  resolvidoEm   DateTime?
  resolvidoPor  String?
  confirmacoesRel Confirmacao[]

  @@map("denuncias")
}

model Confirmacao {
  id         String   @id @default(uuid())
  denunciaId String
  sessionId  String
  criadoEm   DateTime @default(now())
  denuncia   Denuncia @relation(fields: [denunciaId], references: [id])

  @@unique([denunciaId, sessionId])
  @@map("confirmacoes")
}

model Visita {
  id         String   @id @default(uuid())
  visitorId  String
  data       String   // "2026-02-25" (uma entrada por visitante por dia)
  criadoEm   DateTime @default(now())

  @@unique([visitorId, data])
  @@map("visitas")
}

enum TipoPOI {
  QUIOSQUE
  SALVA_VIDAS
  POLICIA
  BANHEIRO
  CHUVEIRO
  ESTACIONAMENTO
  INFORMACAO
  EVENTO
  ENTIDADE
}

model POI {
  id          String   @id @default(uuid())
  tipo        TipoPOI
  nome        String?
  descricao   String?
  latitude    Float
  longitude   Float
  fotoBase64  String?  @db.Text
  criadoEm    DateTime @default(now())
  @@map("pois")
}
